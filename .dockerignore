# =============================================================================
# MPCT-AP | .dockerignore
# Keeps the build context lean. Prevents secrets, local state, and dev
# artifacts from being copied into the production image.
# =============================================================================

# --- Version control ---
.git/
.gitignore
.gitattributes

# --- Python virtual environments ---
.venv/
venv/
env/
ENV/

# --- Python bytecode & caches ---
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- MPCT-AP local session state & checkpoints ---
# These are runtime artifacts that must NOT be baked into the image.
# Cloud Run is stateless; sessions should use GCS or Cloud SQL instead.
mpct_sessions/
sessions/
checkpoints/
*.session
*.pkl

# --- Local output / downloads ---
downloads/
output/
exports/
*.xlsx
*.csv

# --- Node / Frontend build artifacts ---
frontend/node_modules/
frontend/.next/
frontend/build/
frontend/dist/
frontend/.cache/

# --- OS & editor noise ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# --- Environment & secrets (never bake these in!) ---
.env
.env.*
*.pem
*.key
secrets/

# --- Docker files themselves (no need to copy into the image) ---
Dockerfile
.dockerignore
docker-compose*.yml

# --- Documentation & CI (reduces image size) ---
README.md
docs/
.github/
*.md
